<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RSG League Stats</title>

<style>

body{
font-family: Arial, sans-serif;
background:#f2f2f2;
margin:0;
color:#1f2a44;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:15px;
background:white;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.logo{
font-size:22px;
font-weight:bold;
}

.menu-btn{
font-size:24px;
}

.card{
background:white;
margin:20px;
padding:30px;
border-radius:14px;
text-align:center;
box-shadow:0 3px 8px rgba(0,0,0,0.1);
}

.card div{
padding:18px;
font-size:20px;
font-weight:600;
}

.section{
margin:25px;
}

h2{
font-size:32px;
margin-bottom:15px;
}

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:10px;
overflow:hidden;
}

th, td{
padding:12px;
border-bottom:1px solid #ddd;
text-align:left;
}

th{
background:#f7f7f7;
}

.highlight{
background:#cfe0ec;
}

</style>
</head>

